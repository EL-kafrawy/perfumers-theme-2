<footer class="bg-charcoal text-soft-ivory pt-20 pb-10 px-6 font-display" data-section-id="{{ section.id }}">
  <div class="max-w-6xl mx-auto">
    <!-- Top Gold Line -->
    <div class="h-px bg-gradient-to-r from-transparent via-primary/50 to-transparent mb-16 opacity-50"></div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand Block -->
      <div class="flex flex-col">
        <div class="flex flex-col mb-6">
          <div class="mb-2 opacity-80">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#c8a46a" stroke-width="1.5">
              <path d="M5 16l-1-8 4 2 4-7 4 7 4-2-1 8H5z" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="18" r="1.5" fill="#c8a46a"/>
            </svg>
          </div>
          <span class="font-serif text-3xl tracking-[0.3em] text-[#f5f0e8] uppercase leading-none">PERFUMERS</span>
          <span class="font-serif italic text-primary text-base mt-2">fragrance of dreams</span>
        </div>
        <p class="text-xs leading-loose opacity-60 font-light max-w-xs">
          {{ section.settings.about_text }}
        </p>
      </div>

      <!-- Contact Block -->
      <div>
        <h4 class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase mb-6">Contact</h4>
        <ul class="flex flex-col gap-4 text-xs opacity-60 font-light">
          <li>
            <a href="tel:{{ section.settings.phone }}" class="flex items-center gap-3 hover:text-primary transition-all">
              <span class="material-symbols-outlined text-sm text-primary/80">call</span>
              <span>{{ section.settings.phone }}</span>
            </a>
          </li>
          <li>
            <a href="mailto:{{ section.settings.email }}" class="flex items-center gap-3 hover:text-primary transition-all">
              <span class="material-symbols-outlined text-sm text-primary/80">mail</span>
              <span>{{ section.settings.email }}</span>
            </a>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-sm text-primary/80">location_on</span>
            <span>{{ section.settings.location }}</span>
          </li>
        </ul>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase mb-6">Explore</h4>
        <ul class="flex flex-col gap-3 text-xs opacity-60 font-light">
          <li><a href="/pages/the-archive" class="hover:text-primary transition-all">The Archive</a></li>
          <li><a href="/pages/authentication" class="hover:text-primary transition-all">Authentication</a></li>
          <li><a href="/pages/our-story" class="hover:text-primary transition-all">Our Story</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase mb-6">Support</h4>
        <ul class="flex flex-col gap-3 text-xs opacity-60 font-light">
          <li><a href="/pages/shipping-policy" class="hover:text-primary transition-all">Shipping</a></li>
          <li><a href="/pages/returns-policy" class="hover:text-primary transition-all">Returns</a></li>
          <li><a href="/pages/care-guide" class="hover:text-primary transition-all">Care Guide</a></li>
          <li><a href="/pages/contact" class="hover:text-primary transition-all">Contact</a></li>
        </ul>
      </div>
    </div>

    <!-- Gold Ornament Divider -->
    <div class="flex items-center justify-center gap-5 my-16 opacity-30">
      <div class="h-px flex-1 bg-primary"></div>
      <div class="w-2 h-2 border border-primary rotate-45"></div>
      <div class="h-px flex-1 bg-primary"></div>
    </div>

    <!-- Social & Bottom Bar -->
    <div class="pt-10 border-t border-white/10 flex flex-col md:flex-row gap-8 items-center justify-between">
      <div class="flex gap-10">
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-[11px] uppercase tracking-widest opacity-60 hover:opacity-100 hover:text-primary transition-all">
            <span class="material-symbols-outlined text-sm">share</span>
            <span>Facebook</span>
          </a>
        {% endif %}
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-[11px] uppercase tracking-widest opacity-60 hover:opacity-100 hover:text-primary transition-all">
            <span class="material-symbols-outlined text-sm">camera_alt</span>
            <span>Instagram</span>
          </a>
        {% endif %}
        {% if section.settings.social_tiktok != blank %}
          <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-[11px] uppercase tracking-widest opacity-60 hover:opacity-100 hover:text-primary transition-all">
            <svg width="14" height="14" viewBox="0 0 448 512" fill="currentColor" class="opacity-80">
              <path d="M448 209.91a210.06 210.06 0 0 1-122.77-39.25V349.38A162.55 162.55 0 1 1 185 188.31V278.2a74.62 74.62 0 1 0 52.23 71.18V0l88 0 a121.18 121.18 0 0 0 1.86 22.17h.03a122.18 122.18 0 0 0 108.5 118.7v89.04z"/>
            </svg>
            <span>TikTok</span>
          </a>
        {% endif %}
      </div>
      <p class="text-[10px] opacity-30 tracking-[0.2em] uppercase">{{ section.settings.copyright }}</p>
    </div>

    <!-- Trust & Payment Badges -->
    <div class="mt-16 pt-10 border-t border-white/5 flex flex-col items-center gap-10">
      <!-- Trust Line -->
      <div class="text-[10px] tracking-[0.2em] opacity-40 uppercase text-center flex flex-wrap justify-center gap-y-2" style="font-variant: small-caps;">
        <span class="flex items-center gap-2">✔ 100% Authentic</span>
        <span class="hidden md:inline mx-3 opacity-20">|</span>
        <span class="flex items-center gap-2">✔ Secure Checkout</span>
        <span class="hidden md:inline mx-3 opacity-20">|</span>
        <span class="flex items-center gap-2">✔ Free Returns</span>
      </div>

      <!-- Payment Icons -->
      <div class="flex flex-col items-center gap-5">
        <span class="text-[9px] font-bold uppercase tracking-[0.3em] opacity-20">We Accept</span>
        <div class="flex flex-wrap justify-center items-center gap-6 opacity-40 transition-all hover:opacity-70 group">
          <!-- Visa -->
          <svg width="32" height="20" viewBox="0 0 32 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="grayscale group-hover:grayscale-0 transition-all duration-500">
            <path d="M12.422 14.618l2.253-10.091H17.21l-2.253 10.091h-2.535zm11.393-9.845c-.482-.191-1.24-.397-2.186-.397-2.399 0-4.086 1.154-4.1 2.793-.016 1.22 1.205 1.898 2.116 2.302.935.415 1.248.673 1.248 1.04 0 .56-.74 0.817-1.42 0.817-1.192 0-1.826-.165-2.796-.547l-.39-.168-.415 2.316c.686.284 1.956.529 3.27.544 2.553 0 4.214-1.139 4.237-2.906.01-0.969-.64-1.706-2.043-2.31-.852-.387-1.374-.648-1.374-1.044 0-.352.433-.73 1.365-.73.774-.014 1.341.15 1.77.316l.21.089.448-2.115zm5.72 9.845l1.636-10.091h-1.921c-.596 0-1.044.153-1.3.708l-3.327 7.027c-.201-.482-1.343-2.955-1.343-2.955L23.966 4.527h-3.134l4.28 10.091h2.423zm-20.915 0l2.42-10.091H8.618C8.016 4.527 7.518 4.887 7.29 5.378L3.376 13.917C3.376 13.917 4.939 14.618 10.02 14.618z" fill="currentColor"/>
          </svg>
          <!-- Mastercard -->
          <svg width="26" height="20" viewBox="0 0 32 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="grayscale group-hover:grayscale-0 transition-all duration-500">
            <circle cx="11" cy="10" r="10" fill="currentColor" fill-opacity="0.8"/>
            <circle cx="21" cy="10" r="10" fill="currentColor" fill-opacity="0.6"/>
          </svg>
          <!-- Cash on Delivery -->
          <div class="flex items-center gap-2 border border-white/20 px-2 py-1 rounded-[2px]">
            <span class="material-symbols-outlined text-sm">payments</span>
            <span class="text-[8px] font-bold tracking-widest">COD</span>
          </div>
          <!-- InstaPay -->
          <div class="flex items-center gap-2 border border-white/20 px-2 py-1 rounded-[2px]">
            <span class="text-[8px] font-bold tracking-widest" style="color: #4CAF50;">INSTAPAY</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .bg-charcoal { background-color: #2D2926; }
  .text-soft-ivory { color: #F5F1EB; }
  .pt-20 { padding-top: 5rem; }
  .pb-10 { padding-bottom: 2.5rem; }
  .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
  .font-display { font-family: 'Montserrat', sans-serif; }
  .max-w-6xl { max-width: 72rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .h-px { height: 1px; }
  .bg-gradient-to-r { background-image: linear-gradient(to right, transparent, rgba(200,164,106,0.5), transparent); }
  .mb-16 { margin-bottom: 4rem; }
  .opacity-50 { opacity: 0.5; }
  .grid { display: grid; }
  .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
  @media (min-width: 768px) { .md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  .gap-12 { gap: 3rem; }
  .flex { display: flex; }
  .flex-col { flex-direction: column; }
  .mb-6 { margin-bottom: 1.5rem; }
  .mb-2 { margin-bottom: 0.5rem; }
  .opacity-80 { opacity: 0.8; }
  .opacity-60 { opacity: 0.6; }
  .font-serif { font-family: 'Cormorant Garamond', serif; }
  .text-3xl { font-size: 1.875rem; }
  .tracking-\[0\.3em\] { letter-spacing: 0.3em; }
  .text-\[#f5f0e8\] { color: #f5f0e8; }
  .uppercase { text-transform: uppercase; }
  .leading-none { line-height: 1; }
  .italic { font-style: italic; }
  .text-primary { color: #C8A46A; }
  .text-base { font-size: 1rem; }
  .mt-2 { margin-top: 0.5rem; }
  .text-xs { font-size: 0.75rem; }
  .leading-loose { line-height: 2; }
  .font-light { font-weight: 300; }
  .max-w-xs { max-width: 20rem; }
  .text-\[11px\] { font-size: 11px; }
  .font-bold { font-weight: 700; }
  .tracking-\[0\.2em\] { letter-spacing: 0.2em; }
  .gap-4 { gap: 1rem; }
  .gap-3 { gap: 0.75rem; }
  .items-center { align-items: center; }
  .hover\:text-primary:hover { color: #C8A46A; }
  .transition-all { transition: all 0.3s ease; }
  .text-sm { font-size: 0.875rem; }
  .text-primary\/80 { color: rgba(200,164,106,0.8); }
  .gap-5 { gap: 1.25rem; }
  .my-16 { margin-top: 4rem; margin-bottom: 4rem; }
  .opacity-30 { opacity: 0.3; }
  .flex-1 { flex: 1 1 0%; }
  .bg-primary { background-color: #C8A46A; }
  .w-2 { width: 0.5rem; }
  .h-2 { height: 0.5rem; }
  .border { border-width: 1px; border-style: solid; }
  .border-primary { border-color: #C8A46A; }
  .rotate-45 { transform: rotate(45deg); }
  .pt-10 { padding-top: 2.5rem; }
  .border-t { border-top-width: 1px; border-top-style: solid; }
  .border-white\/10 { border-color: rgba(255,255,255,0.1); }
  @media (min-width: 768px) { .md\:flex-row { flex-direction: row; } }
  .gap-8 { gap: 2rem; }
  .justify-between { justify-content: space-between; }
  .gap-10 { gap: 2.5rem; }
  .tracking-widest { letter-spacing: 0.1em; }
  .hover\:opacity-100:hover { opacity: 1; }
  .text-\[10px\] { font-size: 10px; }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "about_text",
      "label": "About text",
      "default": "Premium fragrances, authentically sourced. Every scent delivered across Egypt."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+201065833338"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@perfumers.eg"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Cairo, Egypt"
    },
    {
      "type": "url",
      "id": "link_archive",
      "label": "The Archive link"
    },
    {
      "type": "url",
      "id": "link_authentication",
      "label": "Authentication link"
    },
    {
      "type": "url",
      "id": "link_story",
      "label": "Our Story link"
    },
    {
      "type": "url",
      "id": "link_shipping",
      "label": "Shipping link"
    },
    {
      "type": "url",
      "id": "link_returns",
      "label": "Returns link"
    },
    {
      "type": "url",
      "id": "link_care",
      "label": "Care Guide link"
    },
    {
      "type": "url",
      "id": "link_contact",
      "label": "Contact link"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 PERFUMERS. All rights reserved."
    }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
